# Discord bot token (https://discord.com/developers/applications)
# Required intents: Server Members, Voice States
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Guild ID (right-click server → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Slack bot token (xoxb-...) — required scopes: chat:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Default Slack channel to post transcripts (name or channel ID)
SLACK_DEFAULT_CHANNEL=#warroom

# Path to Whisper GGML model file
# Recommended: ggml-large-v3-french.bin (fine-tuned on French)
# Download: https://huggingface.co/bofenghuang/whisper-large-v3-french/resolve/main/ggml-model.bin
WHISPER_MODEL_PATH=/path/to/ggml-large-v3-french.bin

# Flush interval in seconds — how often a raw batch is posted to Slack
# 30s is good for GPU, 60s+ for CPU with large models
FLUSH_INTERVAL=30
